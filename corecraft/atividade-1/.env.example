# Atividade 1 — alinhado ao `bitcoind` da raiz `corecraft/` (rede `corecraft`, signet).
# Copiar: cp .env.example .env
# Credenciais devem coincidir com BITCOIN_RPC_* no `.env` da raiz do monorepo.

BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_RPC_PORT=38332
BITCOIN_HOST=bitcoind
BITCOIN_NETWORK=signet

# Core noutro sítio (sem stack da raiz): ex. host.docker.internal + porta RPC publicada
