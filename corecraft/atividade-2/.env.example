# Atividade 2 — alinhado ao `bitcoind` da raiz `corecraft/` (rede `corecraft`, signet).
# Copiar: cp .env.example .env

BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_RPC_PORT=38332
BITCOIN_HOST=bitcoind
BITCOIN_NETWORK=signet
BITCOIN_ZMQ_BLOCK=tcp://bitcoind:28332
BITCOIN_ZMQ_TX=tcp://bitcoind:28333
EVENTS_BUFFER_SIZE=300
EVENTS_WINDOW_SECONDS=60
EVENTS_LATEST_LIMIT=20
