{
	default_sni {$CADDY_DEFAULT_SNI}
}

:80 {
	# Base do redirect (sem path). Vem de CADDY_REDIRECT_BASE no compose (por defeito: https://{host}).
	# Com CADDY_HTTP_PORT/CADDY_HTTPS_PORT alternativos, define na raiz .env, ex.:
	# CADDY_REDIRECT_BASE=https://localhost:8443
	redir {$CADDY_REDIRECT_BASE}{uri} permanent
}

{$CADDY_SITE_ADDRESSES} {
	tls internal

	handle_path /a1/api/* {
		reverse_proxy corecraft-a1-backend:8000
	}
	handle /a1/ws/* {
		reverse_proxy corecraft-a1-backend:8000
	}
	# Sem strip do prefixo: o Vite com base /a1/ precisa de ver /a1/... no path; com handle_path recebia / e fazia redirect → ERR_TOO_MANY_REDIRECTS
	handle /a1/* {
		reverse_proxy corecraft-a1-frontend:5173 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto {http.request.scheme}
			header_up X-Forwarded-Host {http.request.host}
		}
	}

	handle_path /a2/api/* {
		reverse_proxy corecraft-a2-backend:8000
	}
	handle /a2/ws/* {
		reverse_proxy corecraft-a2-backend:8000
	}
	handle /a2/* {
		reverse_proxy corecraft-a2-frontend:5173 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto {http.request.scheme}
			header_up X-Forwarded-Host {http.request.host}
		}
	}

	handle_path /a3/api/* {
		reverse_proxy corecraft-a3-backend:8000
	}
	handle /a3/ws/* {
		reverse_proxy corecraft-a3-backend:8000
	}
	handle /a3/* {
		reverse_proxy corecraft-a3-frontend:5173 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto {http.request.scheme}
			header_up X-Forwarded-Host {http.request.host}
		}
	}
}
