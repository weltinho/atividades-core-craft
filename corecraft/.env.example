# Raiz corecraft/ — usado por `docker compose` desta pasta (bitcoind + caddy).
# Copiar: cp .env.example .env

# Bitcoin Core (signet — ver infra/bitcoin/bitcoin.conf)
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_P2P_PORT=38333
BITCOIN_RPC_PORT_HOST=38332

# Caddy
# CADDY_REDIRECT_BASE = URL HTTPS absoluto para o redirect HTTP→HTTPS (sem barra final).
# Com HTTP em 8080 e HTTPS em 8443, define explicitamente (o defeito no compose é https://localhost:8443).
# Com 80/443 padrão: CADDY_REDIRECT_BASE=https://localhost
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_REDIRECT_BASE=https://localhost
CADDY_SITE_ADDRESSES=localhost
CADDY_DEFAULT_SNI=localhost

# Para aceder por IP sem hostname (ex. EC2), alinha com o README:
# CADDY_SITE_ADDRESSES=localhost,127.0.0.1,[::1],SEU_IP_PUBLICO
# CADDY_DEFAULT_SNI=SEU_IP_PUBLICO
